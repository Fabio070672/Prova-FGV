{
  // ==============================================================
  // CONFIGURAÇÃO DO SERVIÇO DE ORDENAÇÃO DE LIVROS
  // ==============================================================
  // Este arquivo permite configurar diferentes estratégias de
  // ordenação sem alterar o código da aplicação.
  // ==============================================================

  "BookSorting": {
    
    // Nome da configuração padrão (usada quando nenhuma é especificada)
    "DefaultConfiguration": "TitleAndAuthor",
    
    // Lista de configurações de ordenação disponíveis
    "Configurations": [
      
      // ????????????????????????????????????????????????????????
      // CONFIGURAÇÃO 1: Ordenar por Título e Autor
      // ????????????????????????????????????????????????????????
      {
        "Name": "TitleAndAuthor",
        "Description": "Ordena por Título e Autor (ambos ascendentes)",
        "Rules": [
          {
            "Attribute": "Title",      // Primeiro critério: Título
            "Direction": "Ascending",  // Ordem crescente (A-Z)
            "Order": 1                 // Prioridade 1 (aplicado primeiro)
          },
          {
            "Attribute": "Author",     // Segundo critério: Autor
            "Direction": "Ascending",  // Ordem crescente (A-Z)
            "Order": 2                 // Prioridade 2 (desempate)
          }
        ]
      },

      // ????????????????????????????????????????????????????????
      // CONFIGURAÇÃO 2: Ordenar por Autor e Edição
      // ????????????????????????????????????????????????????????
      {
        "Name": "AuthorAndEdition",
        "Description": "Ordena por Autor (ascendente) e Edição (descendente)",
        "Rules": [
          {
            "Attribute": "Author",     // Primeiro: Autor
            "Direction": "Ascending",  // Crescente (A-Z)
            "Order": 1
          },
          {
            "Attribute": "Edition",    // Segundo: Edição
            "Direction": "Descending", // Decrescente (mais nova primeiro)
            "Order": 2
          }
        ]
      },

      // ????????????????????????????????????????????????????????
      // CONFIGURAÇÃO 3: Ordenar apenas por Edição
      // ????????????????????????????????????????????????????????
      {
        "Name": "EditionOnly",
        "Description": "Ordena somente por Edição (descendente)",
        "Rules": [
          {
            "Attribute": "Edition",
            "Direction": "Descending", // Edições mais recentes primeiro
            "Order": 1
          }
        ]
      },

      // ????????????????????????????????????????????????????????
      // CONFIGURAÇÃO 4: Ordenação Completa (3 níveis)
      // ????????????????????????????????????????????????????????
      {
        "Name": "CompleteSort",
        "Description": "Ordena por Título, Autor e Edição",
        "Rules": [
          {
            "Attribute": "Title",
            "Direction": "Ascending",
            "Order": 1                 // 1º nível: Título
          },
          {
            "Attribute": "Author",
            "Direction": "Ascending",
            "Order": 2                 // 2º nível: Autor
          },
          {
            "Attribute": "Edition",
            "Direction": "Descending",
            "Order": 3                 // 3º nível: Edição
          }
        ]
      }

      // ????????????????????????????????????????????????????????
      // COMO ADICIONAR NOVA CONFIGURAÇÃO:
      // ????????????????????????????????????????????????????????
      // 1. Copie um dos blocos acima
      // 2. Adicione uma vírgula após o último bloco
      // 3. Modifique Name, Description e Rules
      // 4. Salve o arquivo
      // 5. Reinicie a aplicação
      // 6. Use: GET /api/books?configurationName=SeuNome
      // ????????????????????????????????????????????????????????
      
    ]
  }
}
