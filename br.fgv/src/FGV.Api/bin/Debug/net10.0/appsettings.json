{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=fgv_db;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  },
  "BookSorting": {
    "DefaultConfiguration": "TitleAscending",
    "Configurations": [
      {
        "Name": "TitleAscending",
        "Description": "Título ascendente - Resultado esperado: Livros 3, 4, 1, 2",
        "Rules": [
          {
            "Attribute": "Title",
            "Direction": "Ascending",
            "Order": 1
          }
        ]
      },
      {
        "Name": "AuthorAscendingTitleDescending",
        "Description": "Autor ascendente, Título descendente - Resultado esperado: Livros 1, 4, 3, 2",
        "Rules": [
          {
            "Attribute": "Author",
            "Direction": "Ascending",
            "Order": 1
          },
          {
            "Attribute": "Title",
            "Direction": "Descending",
            "Order": 2
          }
        ]
      },
      {
        "Name": "EditionDescendingAuthorDescendingTitleAscending",
        "Description": "Edição descendente, Autor descendente, Título ascendente - Resultado esperado: Livros 4, 1, 3, 2",
        "Rules": [
          {
            "Attribute": "Edition",
            "Direction": "Descending",
            "Order": 1
          },
          {
            "Attribute": "Author",
            "Direction": "Descending",
            "Order": 2
          },
          {
            "Attribute": "Title",
            "Direction": "Ascending",
            "Order": 3
          }
        ]
      },
      {
        "Name": "TitleAndAuthor",
        "Description": "Fluxo básico: Título e Autor ascendentes",
        "Rules": [
          {
            "Attribute": "Title",
            "Direction": "Ascending",
            "Order": 1
          },
          {
            "Attribute": "Author",
            "Direction": "Ascending",
            "Order": 2
          }
        ]
      }
    ]
  }
}

